{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mydaw.local/schemas/agent-capabilities.schema.json",
  "title": "MyDAW agent capability catalog",
  "description": "Validates the canonical engine and UI operation catalog used by MCP and the in-app agent.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "formatVersion",
    "schemaDialect",
    "schemas",
    "operations",
    "requestExclusions"
  ],
  "properties": {
    "$schema": {
      "const": "./capabilities.schema.json"
    },
    "formatVersion": {
      "const": 1
    },
    "schemaDialect": {
      "const": "https://json-schema.org/draft/2020-12/schema"
    },
    "schemas": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/jsonSchema"
      }
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/operation"
      }
    },
    "requestExclusions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/exclusion"
      }
    }
  },
  "$defs": {
    "jsonSchema": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "object"
        }
      ]
    },
    "supports": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "batch",
          "dryRun",
          "transient"
        ]
      }
    },
    "example": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input"
      ],
      "properties": {
        "input": true,
        "output": true,
        "summary": {
          "type": "string"
        }
      }
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "category",
        "description",
        "target",
        "mode",
        "traits",
        "supports",
        "requires",
        "produces",
        "input",
        "output",
        "examples"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^(?:[a-z][A-Za-z0-9]*/[A-Za-z0-9]+(?:[./][A-Za-z0-9]+)*)$"
        },
        "category": {
          "type": "string",
          "minLength": 2
        },
        "description": {
          "type": "string",
          "minLength": 12,
          "maxLength": 180
        },
        "target": {
          "enum": [
            "engine",
            "command",
            "ui"
          ]
        },
        "mode": {
          "enum": [
            "read",
            "write"
          ]
        },
        "traits": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "mutating",
              "undoable",
              "destructive",
              "filesystem",
              "external",
              "ui-only",
              "idempotent",
              "asynchronous"
            ]
          }
        },
        "supports": {
          "$ref": "#/$defs/supports"
        },
        "requires": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 2
          }
        },
        "produces": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 2
          }
        },
        "input": {
          "$ref": "#/$defs/jsonSchema"
        },
        "output": {
          "$ref": "#/$defs/jsonSchema"
        },
        "examples": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/example"
          }
        }
      }
    },
    "exclusion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request",
        "reason",
        "use"
      ],
      "properties": {
        "request": {
          "type": "string",
          "minLength": 3
        },
        "reason": {
          "type": "string",
          "minLength": 12
        },
        "use": {
          "type": "string",
          "minLength": 12
        }
      }
    }
  }
}
