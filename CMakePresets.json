{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "x64-base",
      "hidden": true,
      "generator": "Visual Studio 18 2026",
      "architecture": { "value": "x64", "strategy": "set" },
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release"
      }
    },
    {
      "name": "x64-release",
      "displayName": "x64 Release (engine + host64)",
      "inherits": "x64-base"
    },
    {
      "name": "x64-debug",
      "displayName": "x64 Debug (engine + host64)",
      "inherits": "x64-base"
    },
    {
      "name": "host32-release",
      "displayName": "Win32 Release (mydaw-host32 only)",
      "generator": "Visual Studio 18 2026",
      "architecture": { "value": "Win32", "strategy": "set" },
      "binaryDir": "${sourceDir}/build32",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release",
        "MYDAW_HOST_ONLY": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "x64-release",
      "configurePreset": "x64-release",
      "configuration": "Release"
    },
    {
      "name": "x64-debug",
      "configurePreset": "x64-debug",
      "configuration": "Debug"
    },
    {
      "name": "host32-release",
      "configurePreset": "host32-release",
      "configuration": "Release"
    }
  ]
}
